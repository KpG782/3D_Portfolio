# EmailJS credentials for the contact form.
# Copy this file to ".env" and fill in your own values from https://dashboard.emailjs.com
# NOTE: .env is gitignored — never commit real keys.

VITE_APP_EMAILJS_SERVICE_ID=your_service_id_here
VITE_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# Google Analytics 4 — Measurement ID from the kenbuilds.tech web stream.
# GA4 property: stream "Ken Garcia" · stream ID 15055292154 · G-8CNSRYZR0X
# (Admin → Data streams). Set in Vercel env (Production/Preview/Development);
# /resume is static HTML, so its tag is hardcoded in public/resume.html.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
